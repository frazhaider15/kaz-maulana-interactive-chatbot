# Copy this file to ".env" and paste your keys below.
# Both keys are read only by the server-side proxies (vite.config.js in dev,
# api/*.js on Vercel) and are never exposed to the browser.
# IMPORTANT: keep real keys in .env (git-ignored), never in this file.

# Anthropic — powers the chatbot answers. https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs — powers the spoken voice (same voice for every user).
# Get a key at https://elevenlabs.io → Profile → API key.
ELEVENLABS_API_KEY=sk_...

# Optional: which ElevenLabs voice to use. Leave blank to use the built-in
# default ("Bill", an older male). On the FREE plan only premade voices work via
# the API (Voice-Library voices return 402); free-tier-OK male voice IDs:
#   Bill pqHfZKP75CvOlQylNhV4 · George JBFqnCBsd6RMkjVDRZzb · Brian nPczCjzI2devNBz1zQrb
#   Daniel onwK4e9ZLuTAKqWW03F9 · Arnold VR6AewLTigWG4xSOukaG · Adam pNInz6obpgDQGcFmaJgB
ELEVENLABS_VOICE_ID=
